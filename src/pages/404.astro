---
import Layout from '../layouts/Layout.astro';
---

<Layout titre="Page introuvable - Échos Sonores">
    <section class="grille bg-[#00b44b] px-8 pt-32 pb-20 font-montserrat text-white lg:pt-40 lg:pb-28">
        <div class="col-span-full flex min-h-[60vh] flex-col items-center justify-center text-center lg:col-span-10 lg:col-start-2 lg:min-h-[70vh]">
            <h1 class="mb-6 text-9xl font-bold lg:text-[12rem] lg:mb-8">404</h1>
            <h2 class="mb-4 text-4xl font-semibold lg:text-5xl lg:mb-6">Page introuvable</h2>
            <p class="mb-8 text-xl lg:text-2xl lg:mb-12">Oups ! La page que vous recherchez n'existe pas ou a été déplacée.</p>
            
            <a 
                href="/" 
                class="rounded-lg bg-[#E30000] px-8 py-4 text-lg font-bold text-white transition-transform hover:scale-105 lg:px-12 lg:py-5 lg:text-xl"
            >
                Retour à l'accueil
            </a>
        </div>
    </section>
</Layout>
