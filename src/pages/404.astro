---
import Layout from '../layouts/Layout.astro';
---

<Layout titre="Page introuvable - Échos Sonores">
    <section class="grille bg-[#00b44b] px-8 pt-32 pb-20 font-montserrat text-white">
        <div class="col-span-full flex min-h-[60vh] flex-col items-center justify-center text-center lg:col-span-10 lg:col-start-2">
            <h1 class="mb-6 text-9xl font-bold">404</h1>
            <h2 class="mb-4 text-4xl font-semibold lg:text-5xl">Page introuvable</h2>
            <p class="mb-8 text-xl">Oups ! La page que vous recherchez n'existe pas ou a été déplacée.</p>
            
            <a 
                href="/" 
                class="rounded-lg bg-[#E30000] px-8 py-4 text-lg font-bold text-white transition-transform hover:scale-105"
            >
                Retour à l'accueil
            </a>
        </div>
    </section>
</Layout>
