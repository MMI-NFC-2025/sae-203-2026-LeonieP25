---
import Layout from '../layouts/Layout.astro';
import instaImg from '../assets/icons/insta.svg';
import xImg from '../assets/icons/x.svg';
import youtubeImg from '../assets/icons/youtube.svg';
---

<Layout titre="Contact - Échos Sonores">
    <section class="grille bg-[#00b44b] px-8 pt-32 pb-20 font-montserrat text-white">
        <header class="col-span-full mb-8 text-center lg:col-span-10 lg:col-start-2">
            <h1 class="text-4xl font-semibold lg:text-5xl">Contact</h1>
        </header>

        <article class="col-span-full mb-12 lg:col-span-10 lg:col-start-2">
            <h2 class="mb-6 text-3xl font-bold">Contactez-nous !</h2>

            <form class="space-y-6" action="#" method="post">
                <div>
                    <label for="lastname" class="sr-only">Nom</label>
                    <input 
                        type="text" 
                        id="lastname" 
                        name="lastname" 
                        placeholder="Nom..." 
                        required 
                        class="w-full rounded-lg bg-white px-6 py-4 text-lg text-[#006711] placeholder-[#006711]/60 focus:outline-none focus:ring-4 focus:ring-white/50"
                    />
                </div>

                <div>
                    <label for="firstname" class="sr-only">Prénom</label>
                    <input 
                        type="text" 
                        id="firstname" 
                        name="firstname" 
                        placeholder="Prénom..." 
                        required 
                        class="w-full rounded-lg bg-white px-6 py-4 text-lg text-[#006711] placeholder-[#006711]/60 focus:outline-none focus:ring-4 focus:ring-white/50"
                    />
                </div>

                <div>
                    <label for="email" class="sr-only">Email</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        placeholder="Email..." 
                        required 
                        class="w-full rounded-lg bg-white px-6 py-4 text-lg text-[#006711] placeholder-[#006711]/60 focus:outline-none focus:ring-4 focus:ring-white/50"
                    />
                </div>

                <div>
                    <label for="message" class="mb-2 block text-lg font-bold">Sujet</label>
                    <textarea 
                        id="message" 
                        name="message" 
                        rows="5" 
                        placeholder="Écrivez votre demande ici..." 
                        required 
                        class="w-full rounded-lg bg-white px-6 py-4 text-lg text-[#006711] placeholder-[#006711]/60 focus:outline-none focus:ring-4 focus:ring-white/50"
                    ></textarea>
                </div>

                <button 
                    type="submit" 
                    class="rounded-lg bg-[#E30000] px-8 py-3 font-bold text-white transition-transform hover:scale-105"
                >
                    Envoyer
                </button>
            </form>
        </article>

        <article class="col-span-full mb-12 lg:col-span-10 lg:col-start-2">
            <h2 class="mb-6 text-3xl font-bold">Nos coordonnées</h2>

            <ul class="space-y-4 text-lg">
                <li class="flex items-start gap-3">
                    <span>Rue de Dasle, Audincourt</span>
                </li>
                <li class="flex items-start gap-3">
                    <a href="mailto:info@echossonores.fr" class="underline hover:no-underline">
                        info@echossonores.fr
                    </a>
                </li>
                <li class="flex items-start gap-3">
                    <a href="tel:+33365885698" class="underline hover:no-underline">
                        03 65 88 56 98
                    </a></span>
                </li>
            </ul>
        </article>

        <article class="col-span-full lg:col-span-10 lg:col-start-2">
            <h2 class="mb-6 text-3xl font-bold">Nos réseaux</h2>

            <ul class="flex gap-6">
                <li>
                    <a href="#" aria-label="Instagram" class="block transition-transform hover:scale-110">
                        <img src={instaImg.src} alt="Instagram" class="h-16 w-16" />
                    </a>
                </li>
                <li>
                    <a href="#" aria-label="X (Twitter)" class="block transition-transform hover:scale-110">
                        <img src={xImg.src} alt="X" class="h-16 w-16" />
                    </a>
                </li>
                <li>
                    <a href="#" aria-label="YouTube" class="block transition-transform hover:scale-110">
                        <img src={youtubeImg.src} alt="YouTube" class="h-16 w-16" />
                    </a>
                </li>
            </ul>
        </article>
    </section>
</Layout>
