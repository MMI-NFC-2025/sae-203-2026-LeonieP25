---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getSceneById, getImageUrl, getAllArtistesByDate } from "../../../backend/backend.mjs";

const { id } = Astro.params;

let scene = await getSceneById(id);

if (!scene) {
    return Astro.redirect("/scenes");
}

const imageUrl = scene.photo_scene ? await getImageUrl(scene, scene.photo_scene) : null;

let allArtistes = await getAllArtistesByDate();
let artistesScene = allArtistes.filter((artiste: any) => artiste.scene_representation === id);

let artistesAvecImages = [];
for (const artiste of artistesScene) {
    const artisteImageUrl = artiste.photo_artiste ? await getImageUrl(artiste, artiste.photo_artiste) : null;
    artistesAvecImages.push({ ...artiste, imageUrl: artisteImageUrl });
}
---

<Layout titre={`${scene.nom_scene} - Échos Sonores`}>
    <section class="grille bg-[#00b44b] px-8 pt-32 pb-20 font-montserrat text-white lg:pt-40 lg:pb-28">
        <div class="col-span-full lg:col-span-10 lg:col-start-2">
            <a href="/scenes" class="mb-6 inline-block text-lg underline hover:no-underline lg:text-xl lg:mb-10">← Retour aux scènes</a>
            
            <div class="grid gap-8 md:grid-cols-2 lg:gap-12">
                {imageUrl && (
                    <div class="overflow-hidden rounded-2xl">
                        <img 
                            src={imageUrl} 
                            alt={scene.nom_scene}
                            class="h-full w-full object-cover"
                        />
                    </div>
                )}
                
                <div>
                    <h1 class="mb-4 text-5xl font-bold lg:text-6xl lg:mb-6">{scene.nom_scene}</h1>
                    
                    {scene.description && (
                        <div class="text-lg mb-6 lg:text-xl lg:mb-8">
                            <p>{scene.description}</p>
                        </div>
                    )}
                </div>
            </div>

            {artistesAvecImages.length > 0 && (
                <div class="mt-12 lg:mt-16">
                    <h2 class="mb-6 text-3xl font-bold lg:text-4xl lg:mb-10">Artistes sur cette scène</h2>
                    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
                        {artistesAvecImages.map((artiste: any) => {
                            const dateStr = artiste.dateheure_representation.replace('T', ' ').replace('Z', '').substring(0, 16);
                            
                            return (
                                <a href={`/artistes/${artiste.id}`} class="block overflow-hidden rounded-2xl bg-white shadow-lg transition-transform hover:scale-105">
                                    <div class="relative aspect-4/3">
                                        {artiste.imageUrl ? (
                                            <img 
                                                src={artiste.imageUrl} 
                                                alt={artiste.nom_artiste}
                                                class="h-full w-full object-cover"
                                            />
                                        ) : (
                                            <div class="flex h-full items-center justify-center bg-[#006711]">
                                                <p class="text-2xl font-bold text-white">{artiste.nom_artiste}</p>
                                            </div>
                                        )}
                                    </div>
                                    <div class="p-4">
                                        <p class="text-xl font-bold text-[#00b44b]">{artiste.nom_artiste}</p>
                                        <p class="text-sm text-[#006711]">{dateStr}</p>
                                    </div>
                                </a>
                            );
                        })}
                    </div>
                </div>
            )}
        </div>
    </section>
</Layout>
