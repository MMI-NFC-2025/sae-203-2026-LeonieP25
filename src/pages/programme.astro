---
import Layout from '../layouts/Layout.astro';
import { getAllArtistesByDate } from '../../backend/backend.mjs';

// On récupère les artistes avec leur date/heure et scène depuis PocketBase
const artistes = await getAllArtistesByDate();
---

<Layout titre="Programme - Échos Sonores">
    <section class="grille bg-[#00b44b] px-8 pt-32 pb-20 font-montserrat text-white lg:pt-40 lg:pb-28">
        <header class="col-span-full mb-4 text-center lg:col-span-10 lg:col-start-2 lg:mb-10">
            <h1 class="text-4xl font-semibold lg:text-5xl">Programmation</h1>
        </header>

        <div class="col-span-full overflow-x-auto lg:col-span-10 lg:col-start-2">
            <table class="w-full border-collapse text-left">
                <thead>
                    <tr class="border-b-2 border-white/30">
                        <th class="px-4 py-4 text-lg font-bold lg:text-xl lg:px-6 lg:py-5">Artiste</th>
                        <th class="px-4 py-4 text-lg font-bold lg:text-xl lg:px-6 lg:py-5">Date & Heure</th>
                        <th class="px-4 py-4 text-lg font-bold lg:text-xl lg:px-6 lg:py-5">Scène</th>
                    </tr>
                </thead>
                <tbody>
                {artistes.map((artiste) => {
                    const dateStr = artiste.dateheure_representation.replace('T', ' ').replace('Z', '').substring(0, 16);
                    return (
                    <tr class="border-b border-white/20">
                        <td class="px-4 py-4 text-base lg:text-lg lg:px-6 lg:py-5">{artiste.nom_artiste}</td>
                        <td class="px-4 py-4 text-base lg:text-lg lg:px-6 lg:py-5">{dateStr}</td>
                        <td class="px-4 py-4 text-base lg:text-lg lg:px-6 lg:py-5">
                            {artiste.expand && artiste.expand.scene_representation ? artiste.expand.scene_representation.nom_scene : 'Non définie'}
                        </td>
                    </tr>
                    );
                })}
                </tbody>
            </table>
        </div>

        <div class="col-span-full mt-12 flex justify-center lg:col-span-10 lg:col-start-2 lg:mt-16">
            <a 
                href="/assets/pdf/programme-echos-sonores.pdf"
                class="rounded-lg bg-[#E03000] px-8 py-4 text-center text-lg font-bold transition-transform hover:scale-105 lg:px-12 lg:py-5 lg:text-xl"
            >
                Télécharger<br>le programme
            </a> 
        </div>
    </section>
</Layout>
