---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getAllArtistesByDate, getImageUrl } from '../../../backend/backend.mjs';

let artistes = await getAllArtistesByDate();

let artistesAvecImages = [];
for (const artiste of artistes) {
    const imageUrl = artiste.photo_artiste ? await getImageUrl(artiste, artiste.photo_artiste) : null;
    artistesAvecImages.push({ ...artiste, imageUrl });
}
---

<Layout titre="Artistes - Échos Sonores">
    <section class="grille bg-[#00b44b] px-8 pt-32 pb-20 font-montserrat text-white">
        <header class="col-span-full mb-8 text-center lg:col-span-10 lg:col-start-2">
            <h1 class="text-4xl font-semibold lg:text-5xl">Artistes</h1>
        </header>

        <div class="col-span-full mb-6 lg:col-span-10 lg:col-start-2">
            <ul class="flex flex-wrap justify-center gap-4">
                <li>
                    <button class="date-filter rounded-lg bg-white px-6 py-2 font-bold text-[#00b44b]" data-date="all">
                        Tous
                    </button>
                </li>
                <li>
                    <button class="date-filter rounded-lg bg-[#006711] px-6 py-2 font-bold text-white" data-date="28">
                        28 oct.
                    </button>
                </li>
                <li>
                    <button class="date-filter rounded-lg bg-[#006711] px-6 py-2 font-bold text-white" data-date="29">
                        29 oct.
                    </button>
                </li>
                <li>
                    <button class="date-filter rounded-lg bg-[#006711] px-6 py-2 font-bold text-white" data-date="30">
                        30 oct.
                    </button>
                </li>
                <li>
                    <button class="date-filter rounded-lg bg-[#006711] px-6 py-2 font-bold text-white" data-date="31">
                        31 oct.
                    </button>
                </li>
            </ul>
        </div>

        <div class="col-span-full mb-8 lg:col-span-10 lg:col-start-2">
            <label for="searchArtist" class="mb-3 block text-lg font-bold">Rechercher par Scène ou Nom</label>
            <input 
                type="search" 
                id="searchArtist" 
                placeholder="Nom de l'artiste ou de la scène" 
                class="w-full rounded-2xl bg-[#ffffff] px-6 py-4 text-white text-lg placeholder-black/90 shadow-lg transition-all focus:outline-none focus:ring-4 focus:ring-[#e30000]/50"
            />
        </div>

        <ul id="artistsList" class="col-span-full grid gap-6 md:grid-cols-2 lg:col-span-10 lg:col-start-2 lg:grid-cols-3">
            {artistesAvecImages.map((artiste: any) => {
                const date = new Date(artiste.dateheure_representation);
                const day = date.getDate();
                const sceneName = artiste.expand && artiste.expand.scene_representation ? artiste.expand.scene_representation.nom_scene : '';
                
                const dateStr = artiste.dateheure_representation.replace('T', ' ').replace('Z', '').substring(0, 16);
                
                return (
                    <li class="artist-card overflow-hidden rounded-2xl" data-name={artiste.nom_artiste.toLowerCase()} data-scene={sceneName.toLowerCase()} data-date={day}>
                        <a href={`/artistes/${artiste.id}`}>
                            <div class="relative aspect-4/3">
                                {artiste.imageUrl ? (
                                    <img 
                                        src={artiste.imageUrl} 
                                        alt={artiste.nom_artiste}
                                        class="h-full w-full object-cover"
                                    />
                                ) : (
                                    <div class="h-full w-full bg-gray-700"></div>
                                )}
                                <div class="absolute bottom-0 left-0 right-0 bg-linear-to-t from-black/80 to-transparent p-4">
                                    <p class="text-xl font-bold text-white">{artiste.nom_artiste}</p>
                                    <p class="text-sm text-white">{dateStr}</p>
                                    {sceneName && <p class="text-sm text-white">Scène : {sceneName}</p>}
                                </div>
                            </div>
                        </a>
                    </li>
                );
            })}
        </ul>

        <div id="noResults" class="col-span-full mt-8 hidden text-center text-xl">
            Aucun artiste ne correspond à votre recherche.
        </div>
    </section>

    <script>
        const searchInput = document.getElementById('searchArtist') as HTMLInputElement | null;
        const artistCards = document.querySelectorAll('.artist-card');
        const noResults = document.getElementById('noResults');
        const dateFilters = document.querySelectorAll('.date-filter');
        
        let currentDateFilter = 'all';

        dateFilters.forEach((btn) => {
            btn.addEventListener('click', function(this: HTMLButtonElement) {
                currentDateFilter = this.dataset.date || 'all';
                
                dateFilters.forEach((b) => {
                    b.classList.remove('bg-white', 'text-[#00b44b]');
                    b.classList.add('bg-[#006711]', 'text-white');
                });
                
                this.classList.remove('bg-[#006711]', 'text-white');
                this.classList.add('bg-white', 'text-[#00b44b]');
                
                filterCards();
            });
        });

        if (searchInput) {
            searchInput.addEventListener('input', function() {
                filterCards();
            });
        }

        function filterCards() {
            if (!searchInput) return;
            const searchTerm = searchInput.value.toLowerCase();
            let visibleCount = 0;

            artistCards.forEach((card) => {
                const htmlCard = card as HTMLElement;
                const artistName = htmlCard.dataset.name || '';
                const sceneName = htmlCard.dataset.scene || '';
                const cardDate = htmlCard.dataset.date || '';
                
                const matchesSearch = artistName.includes(searchTerm) || sceneName.includes(searchTerm);
                const matchesDate = currentDateFilter === 'all' || cardDate === currentDateFilter;
                
                if (matchesSearch && matchesDate) {
                    htmlCard.style.display = 'block';
                    visibleCount++;
                } else {
                    htmlCard.style.display = 'none';
                }
            });

            if (noResults) {
                if (visibleCount === 0) {
                    noResults.classList.remove('hidden');
                } else {
                    noResults.classList.add('hidden');
                }
            }
        }
    </script>
</Layout>
