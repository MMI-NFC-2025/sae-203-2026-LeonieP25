---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { titre } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Familjen+Grotesk:wght@400;600;700&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{titre}</title>
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />

		<script>
			// @ts-nocheck
			const backToTopBtn = document.createElement('button');
			backToTopBtn.type = 'button';
			backToTopBtn.className = 'back-to-top';
			backToTopBtn.setAttribute('aria-label', 'Remonter en haut');
			backToTopBtn.setAttribute('aria-hidden', 'true');
			backToTopBtn.textContent = '↑';
			document.body.appendChild(backToTopBtn);

			const menuBtn = document.getElementById('menu-btn');
			const mainNav = document.getElementById('mainNav');

			const toggleBackToTop = () => {
				const isMenuOpen = mainNav && mainNav.getAttribute('aria-hidden') === 'false';
				const isScrolledDown = window.scrollY > 200;
				const shouldShow = isScrolledDown && !isMenuOpen;
				
				backToTopBtn.classList.toggle('is-visible', shouldShow);
				backToTopBtn.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
			};

			backToTopBtn.addEventListener('click', () => {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});

			window.addEventListener('scroll', toggleBackToTop, { passive: true });
			
			if (menuBtn) {
				menuBtn.addEventListener('click', () => {
					setTimeout(toggleBackToTop, 50);
				});
			}
			
			toggleBackToTop();
		</script>
	</body>
</html>


