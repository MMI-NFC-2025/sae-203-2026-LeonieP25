---
import { getImageUrl } from '../../backend/backend.mjs';

const { artiste } = Astro.props;

const imageUrl = artiste.photo_artiste ? await getImageUrl(artiste, artiste.photo_artiste) : null;
const dateStr = artiste.dateheure_representation.replace('T', ' ').replace('Z', '').substring(0, 16);
---

<li class="overflow-hidden rounded-2xl">
    <a href={`/artistes/${artiste.id}`}>
        <div class="relative aspect-[4/3]">
            {imageUrl ? (
                <img 
                    src={imageUrl} 
                    alt={artiste.nom_artiste}
                    class="h-full w-full object-cover"
                />
            ) : (
                <div class="h-full w-full bg-gray-700"></div>
            )}
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-4">
                <p class="font-bold text-white text-xl">{artiste.nom_artiste}</p>
                <p class="text-white text-sm">{dateStr}</p>
            </div>
        </div>
    </a>
</li>
